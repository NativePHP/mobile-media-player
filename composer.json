{
    "name": "nativephp/mobile-media-player",
    "description": "Media player plugin for NativePHP Mobile - shared audio/video playback, full-screen presentation, and a video-player element",
    "type": "nativephp-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "Bifrost Technology, LLC",
            "email": "support@nativephp.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "nativephp/mobile": "^3.0 || ^4.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^2.7|^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "NativePHP\\MediaPlayer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "NativePHP\\MediaPlayer\\MediaPlayerServiceProvider"
            ]
        },
        "nativephp": {
            "manifest": "nativephp.json"
        }
    },
    "scripts": {
        "test": "pest"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
